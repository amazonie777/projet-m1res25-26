pipeline {
    agent any

    options {
        skipDefaultCheckout(true)
    }

    environment {
        REPO_URL = 'https://github.com/amazonie777/projet-m1res25-26.git'
        GIT_BRANCH_NAME = 'main'
        CONTAINER_NAME = 'site-nginx'
        SITE_PORT = '8081'
    }

    stages {
        stage('CleanUp de Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Cloner le GitHub') {
            steps {
                git branch: "${GIT_BRANCH_NAME}", url: "${REPO_URL}"
            }
        }

        stage('Installer Docker') {
            steps {
                sh '''
                    set -e
                    export DEBIAN_FRONTEND=noninteractive

                    echo "=== 1. Vérification sudo ==="
                    sudo -n true

                    echo "=== 2. Nettoyage des paquets conflictuels ==="
                    sudo apt-get remove -y docker.io docker-doc docker-compose docker-compose-v2 podman-docker containerd runc || true

                    echo "=== 3. Configuration des prérequis ==="
                    sudo apt-get update
                    sudo apt-get install -y ca-certificates curl gnupg git

                    echo "=== 4. Ajout de la clé Docker ==="
                    sudo install -m 0755 -d /etc/apt/keyrings
                    sudo curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc
                    sudo chmod a+r /etc/apt/keyrings/docker.asc

                    echo "=== 5. Ajout du dépôt Docker Ubuntu ==="
                    . /etc/os-release

                    {
                        echo "Types: deb"
                        echo "URIs: https://download.docker.com/linux/ubuntu"
                        echo "Suites: ${UBUNTU_CODENAME:-$VERSION_CODENAME}"
                        echo "Components: stable"
                        echo "Architectures: $(dpkg --print-architecture)"
                        echo "Signed-By: /etc/apt/keyrings/docker.asc"
                    } | sudo tee /etc/apt/sources.list.d/docker.sources > /dev/null

                    echo "=== 6. Installation de Docker Engine ==="
                    sudo apt-get update
                    sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

                    echo "=== 7. Configuration des droits et services ==="
                    sudo systemctl enable docker
                    sudo systemctl restart docker

                    sudo groupadd docker 2>/dev/null || true
                    sudo usermod -aG docker jenkins || true
                    sudo usermod -aG docker amazigh || true

                    echo "=== 8. Test Docker ==="
                    sudo docker --version
                    sudo docker compose version || true
                    sudo docker run --rm hello-world
                '''
            }
        }

        stage('Trouver le site') {
            steps {
                sh '''
                    set -e

                    echo "=== Recherche du fichier index.html ==="

                    INDEX_FILE=$(find "$WORKSPACE" -maxdepth 4 -iname "index.html" | head -n 1 || true)

                    if [ -z "$INDEX_FILE" ]; then
                        echo "Erreur : aucun index.html trouvé dans le dépôt."
                        echo "Fichiers trouvés :"
                        find "$WORKSPACE" -maxdepth 4 -type f
                        exit 1
                    fi

                    SITE_DIR=$(dirname "$INDEX_FILE")

                    echo "$SITE_DIR" > /tmp/site_dir_jenkins.txt

                    echo "index.html trouvé : $INDEX_FILE"
                    echo "Dossier du site : $SITE_DIR"
                '''
            }
        }

        stage('Déployer avec Nginx') {
            steps {
                sh '''
                    set -e

                    SITE_DIR=$(cat /tmp/site_dir_jenkins.txt)

                    echo "=== Nettoyage ancien conteneur ==="
                    sudo docker stop site-nginx || true
                    sudo docker rm site-nginx || true

                    echo "=== Lancement Nginx ==="
                    sudo docker run -d \
                        --name site-nginx \
                        -p 8081:80 \
                        -v "$SITE_DIR":/usr/share/nginx/html:ro \
                        nginx:latest

                    echo "=== Conteneurs actifs ==="
                    sudo docker ps
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline terminé avec succès. Site disponible sur le port 8081.'
        }

        failure {
            echo 'Pipeline échoué. Regarde l’étape en rouge dans les logs Jenkins.'
        }
    }
}
